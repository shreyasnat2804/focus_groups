        "Bash(pip *)",
        "Bash(pip3 *)",
        "Bash(psql *)",
        "Bash(/opt/homebrew/opt/postgresql@16/bin/psql *)",
        "Bash(/opt/homebrew/opt/postgresql@16/bin/createuser *)",
        "Bash(/opt/homebrew/opt/postgresql@16/bin/createdb *)",
        "Bash(git status*)",
        "Bash(git log*)",
        "Bash(git diff*)",
        "Bash(git branch*)",
        "Bash(git stash*)",
        "Bash(git add *)",
        "Bash(git commit *)",
        "Bash(docker *)",
        "Bash(docker-compose *)",
        "Bash(gcloud * list*)",
        "Bash(gcloud * describe*)",
        "Bash(gsutil ls*)",
        "Bash(gsutil cp*)",
        "Bash(gsutil cat*)",
        "Bash(curl *)",
        "Bash(npm *)",
        "Bash(npx *)",
        "Bash(brew install *)",
        "Bash(brew services *)",
        "Bash(mkdir *)",
        "Bash(mkdir -p *)",
        "Bash(ls *)",
        "Bash(cat *)",
        "Bash(cp *)",
        "Bash(/opt/homebrew/*)",
        "Bash(mv *)",
        "Bash(touch *)",
        "Bash(chmod *)",
