      "deny": [
        "Bash(rm -rf *)",
        "Bash(git push --force*)",
        "Bash(*DROP TABLE*)",
        "Bash(*DROP DATABASE*)",
        "Bash(*DROP SCHEMA*)",
        "Bash(cat .env*)",
        "Bash(gcloud * delete*)",
        "Bash(gsutil rm -r*)"
      ],
      "ask": [
        "Bash(git push*)",
        "Bash(gcloud run deploy*)",
        "Bash(gcloud sql instances create*)",
        "Bash(gcloud compute instances create*)",
        "Bash(gcloud services enable*)"
      ]
    }
  }