# Focus Groups API
# Set to enable API key authentication. Leave empty/unset to disable (local dev).
FG_API_KEY=

# CORS — comma-separated allowed origins. Defaults to localhost:5173,localhost:3000 for dev.
CORS_ORIGINS=https://your-frontend.run.app

# Database
DATABASE_URL=postgresql://localhost:5432/focus_groups

# Claude
ANTHROPIC_API_KEY=
